# ══════════════════════════════════════════════════════
# SMARTGATE ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════
# HOW TO USE:
# 1. Copy this file and rename it to .env
# 2. Fill in your actual values
# 3. Never commit .env to git — only commit .env.example
# ══════════════════════════════════════════════════════

# ── AI Provider Keys (add whichever you use) ──────────
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENAI_API_KEY=your_openai_key_here

# ── Optional Settings ─────────────────────────────────
# These are already set to defaults inside SmartGate
# Only add here if you want to override defaults

# REJECTION_THRESHOLD=5
# QUEUE_LIMIT=100
# MAX_DATA_SIZE=1024
# RESET_DAYS=30
# PORT=8000